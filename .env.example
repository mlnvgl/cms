# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ─── Storage ──────────────────────────────────────────────────────
# Which backend to use: "memory" | "markdown-webdav"
STORAGE_PROVIDER=memory

# Required when STORAGE_PROVIDER=markdown-webdav
# WEBDAV_URL=https://your-nextcloud.example.com/remote.php/dav/files/username
# WEBDAV_USERNAME=your-username
# WEBDAV_PASSWORD=your-app-password
# WEBDAV_BASE_PATH=/cms-content

# Database (for a future database provider)
# DATABASE_URL=postgresql://user:password@localhost:5432/cms

# Auth
# JWT_SECRET=change-me
