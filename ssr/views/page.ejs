<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | SSR CMS</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="layout">
      <nav>
        <ul>
          <% nav.forEach(function(page) { %>
          <li>
            <a href="/<%= page.slug %>"><%= page.title %></a>
          </li>
          <% }) %>
        </ul>
      </nav>
      <main class="page">
        <%- content %>
      </main>
    </div>
  </body>
</html>
